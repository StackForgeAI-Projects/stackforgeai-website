# ─────────────────────────────────────────────────────────────────
# StackForgeAI Website — Environment Variables (template)
# ─────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. All production secrets live in Vercel.
# ─────────────────────────────────────────────────────────────────

# ── Site metadata ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://stackforgeai.africa
NEXT_PUBLIC_SITE_NAME=StackForgeAI

# Optional: Google Analytics 4 measurement ID (gtag). Omit on preview/staging to avoid polluting prod property.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-B6L6MMCVFH

# ── Contact / Transactional email (Resend) ───────────────────────
# Sign up: https://resend.com — verify stackforgeai.africa + send.stackforgeai.africa
# IMPORTANT: From must NOT equal To (same mailbox → junk). Use send.* subdomain for From.
# See docs/EMAIL_DELIVERABILITY.md for SPF/DKIM/DMARC checklist.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_FROM_EMAIL="StackForgeAI Contact Form <contact@send.stackforgeai.africa>"
CONTACT_TO_EMAIL=hello@stackforgeai.africa

# ── Newsletter (Brevo, formerly Sendinblue) ──────────────────────
# Sign up: https://brevo.com — get API key from SMTP & API settings
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxx
BREVO_LIST_ID=3
BREVO_DOUBLE_OPT_IN_TEMPLATE_ID=1

# ── Rate limiting (Upstash Redis) ────────────────────────────────
# Free tier: https://upstash.com — REST URL + token
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Error tracking (Sentry) ──────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=stackforgeai
SENTRY_PROJECT=stackforgeai-website

# ── Calendly ─────────────────────────────────────────────────────
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/stackforgeai/demo

# ── WhatsApp business contact ────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=+250000000000
NEXT_PUBLIC_WHATSAPP_DISPLAY=+250 XXX XXX XXX

# ── Optional analytics (Plausible self-hosted or cloud) ──────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=stackforgeai.africa
