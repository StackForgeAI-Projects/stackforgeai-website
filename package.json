{
  "name": "stackforgeai-website",
  "version": "1.0.0",
  "private": true,
  "description": "StackForgeAI — Intelligent software powering Africa's institutions and businesses. Production marketing site.",
  "author": "StackForgeAI Engineering <hello@stackforgeai.africa>",
  "license": "UNLICENSED",
  "homepage": "https://stackforgeai.africa",
  "repository": {
    "type": "git",
    "url": "git@github.com:StackForgeAI-Projects/stackforgeai-website.git"
  },
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@11.0.9",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "import-in-the-middle": "1.15.0",
      "require-in-the-middle": "7.5.2"
    }
  },
  "scripts": {
    "dev": "pnpm exec kill-port 3000; next dev --turbopack --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps",
    "lhci": "lhci autorun",
    "analyze": "ANALYZE=true next build",
    "audit": "pnpm audit --prod --audit-level=high",
    "clean": "rm -rf .next out node_modules .turbo coverage playwright-report test-results",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@calcom/embed-react": "^1.5.3",
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-email/components": "^0.0.34",
    "@react-email/render": "^1.0.5",
    "@sentry/nextjs": "^9.5.0",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.4",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "gsap": "^3.13.0",
    "lucide-react": "^0.475.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "resend": "^4.1.2",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.20.0",
    "@lhci/cli": "^0.14.0",
    "@next/bundle-analyzer": "^15.1.6",
    "@playwright/test": "^1.50.1",
    "@tailwindcss/postcss": "^4.0.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.5",
    "eslint": "^10.4.1",
    "eslint-config-next": "^15.1.6",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "kill-port": "^2.0.1",
    "lint-staged": "^15.4.3",
    "postcss": "^8.5.2",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.0.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
